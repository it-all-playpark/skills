{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Journal Entry",
  "description": "Skill execution journal entry for retrospective analysis",
  "type": "object",
  "required": ["version", "id", "timestamp", "skill", "outcome"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version"
    },
    "id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}-[0-9]{2}-[0-9]{2}Z-.+$",
      "description": "Unique entry ID: {timestamp}-{skill}"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of skill execution"
    },
    "skill": {
      "type": "string",
      "description": "Name of the executed skill"
    },
    "args": {
      "type": "string",
      "description": "Arguments passed to the skill"
    },
    "outcome": {
      "type": "string",
      "enum": ["success", "failure", "partial"],
      "description": "Execution outcome"
    },
    "duration_turns": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of agentic turns consumed"
    },
    "context": {
      "type": "object",
      "properties": {
        "project": {
          "type": "string",
          "description": "Project name or path"
        },
        "issue": {
          "type": "integer",
          "description": "GitHub issue number"
        },
        "worktree": {
          "type": "string",
          "description": "Worktree path if applicable"
        }
      },
      "additionalProperties": true,
      "description": "Execution context"
    },
    "error": {
      "type": "object",
      "properties": {
        "phase": {
          "type": "string",
          "description": "Phase where error occurred (e.g., 4_validate)"
        },
        "message": {
          "type": "string",
          "description": "Error message or description"
        },
        "category": {
          "type": "string",
          "enum": ["lint", "test", "build", "runtime", "config", "env", "merge", "type-check"],
          "description": "Error classification category"
        }
      },
      "required": ["message", "category"],
      "description": "Error details (present when outcome is failure or partial)"
    },
    "recovery": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "description": "What was done to recover"
        },
        "successful": {
          "type": "boolean",
          "description": "Whether recovery succeeded"
        },
        "turns_spent": {
          "type": "integer",
          "minimum": 0,
          "description": "Turns spent on recovery"
        }
      },
      "description": "Recovery information (present when outcome is failure or partial)"
    }
  }
}
