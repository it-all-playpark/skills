{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Flow State v2",
  "description": "State persistence for dev-flow child-split orchestration. v2 (batch 配列 / child-issue 分割) のみ受理。旧 v1 (depends_on DAG / subtasks / contract) は schema error。",
  "type": "object",
  "required": ["version", "issue", "status", "integration_branch", "children", "batches", "config"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "2.0.0",
      "description": "Schema version. v2 のみ受理。v1 形式は schema error。"
    },
    "issue": {
      "type": "integer",
      "description": "Parent GitHub issue number"
    },
    "status": {
      "type": "string",
      "enum": ["decomposing", "running", "integrated", "failed"],
      "description": "Overall flow status"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "integration_branch": {
      "$ref": "#/$defs/integration_branch",
      "description": "Integration branch where child PRs are merged"
    },
    "children": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/child" },
      "description": "Child issues created from parent"
    },
    "batches": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/batch" },
      "description": "Execution batches. 各 batch は serial / parallel mode を持つ"
    },
    "final_pr": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "number": { "type": "integer" },
        "url": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "description": "Final integration → dev/main PR information"
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["tdd", "bdd", "ddd", "none"],
          "default": "tdd"
        },
        "depth": {
          "type": "string",
          "enum": ["minimal", "standard", "comprehensive"],
          "default": "standard"
        },
        "lang": {
          "type": "string",
          "enum": ["ja", "en"],
          "default": "ja"
        },
        "base_branch": {
          "type": "string",
          "default": "dev",
          "description": "Final integration target (dev / main)"
        },
        "env_mode": {
          "type": "string",
          "enum": ["hardlink", "symlink", "copy", "none"],
          "default": "hardlink"
        }
      }
    }
  },
  "$defs": {
    "integration_branch": {
      "type": "object",
      "required": ["name", "base"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^integration/issue-[0-9]+-[a-z0-9-]+$",
          "description": "Integration branch name (e.g. integration/issue-93-foo)"
        },
        "base": {
          "type": "string",
          "description": "Base branch this integration branch was created from"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "child": {
      "type": "object",
      "required": ["issue", "slug", "scope", "status"],
      "additionalProperties": false,
      "properties": {
        "issue": {
          "type": "integer",
          "description": "Child GitHub issue number"
        },
        "slug": {
          "type": "string",
          "description": "Short identifier for the child (used in branch names, logs)"
        },
        "scope": {
          "type": "string",
          "description": "Human-readable scope description"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "completed", "failed"],
          "default": "pending"
        },
        "pr_number": {
          "type": ["integer", "null"]
        },
        "pr_url": {
          "type": ["string", "null"]
        },
        "merged_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "error": {
          "type": ["string", "null"]
        }
      }
    },
    "batch": {
      "type": "object",
      "required": ["batch", "mode", "children"],
      "additionalProperties": false,
      "properties": {
        "batch": {
          "type": "integer",
          "minimum": 1,
          "description": "1-indexed batch number"
        },
        "mode": {
          "type": "string",
          "enum": ["serial", "parallel"],
          "description": "Execution mode for this batch"
        },
        "children": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer" },
          "description": "Child issue numbers assigned to this batch"
        }
      }
    }
  }
}
