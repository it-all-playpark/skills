{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Flow State",
  "description": "State persistence for dev-flow parallel subtask orchestration",
  "type": "object",
  "required": ["version", "issue", "status", "subtasks", "config"],
  "properties": {
    "version": {
      "type": "string",
      "const": "2.0.0",
      "description": "Schema version"
    },
    "issue": {
      "type": "integer",
      "description": "GitHub issue number"
    },
    "status": {
      "type": "string",
      "enum": ["analyzing", "decomposing", "implementing", "integrating", "pr", "iterating", "completed", "failed"],
      "description": "Overall flow status"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when flow was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "analysis": {
      "type": "object",
      "properties": {
        "requirements": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Extracted requirements from issue"
        },
        "affected_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Files identified as needing changes"
        }
      },
      "description": "Issue analysis results"
    },
    "contract": {
      "type": "object",
      "properties": {
        "branch": {
          "type": "string",
          "description": "Contract branch name (e.g. feature/issue-42-contract)"
        },
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Files containing shared interface/type definitions"
        },
        "committed_at": {
          "type": "string",
          "format": "date-time",
          "description": "When contract was committed"
        }
      },
      "description": "Shared contract (interfaces/types) committed before subtask execution"
    },
    "subtasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/subtask" },
      "description": "Decomposed subtask definitions"
    },
    "shared_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/shared_finding" },
      "default": [],
      "description": "Cross-worker knowledge channel (Shared State pattern). Parallel dev-kickoff workers append breaking changes / design decisions here so other workers can incorporate them into their plans. dev-integrate verifies all findings are acknowledged before merging. Optional; legacy flow.json without this field remains valid."
    },
    "integration": {
      "$ref": "#/$defs/integration",
      "description": "Integration phase state"
    },
    "pr": {
      "type": ["object", "null"],
      "properties": {
        "number": { "type": "integer" },
        "url": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "description": "PR information after creation"
    },
    "config": {
      "type": "object",
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["tdd", "bdd", "ddd", "none"],
          "default": "tdd"
        },
        "depth": {
          "type": "string",
          "enum": ["minimal", "standard", "comprehensive"],
          "default": "standard"
        },
        "lang": {
          "type": "string",
          "enum": ["ja", "en"],
          "default": "ja"
        },
        "base_branch": {
          "type": "string",
          "default": "main"
        },
        "env_mode": {
          "type": "string",
          "enum": ["hardlink", "symlink", "copy", "none"],
          "default": "hardlink"
        }
      },
      "description": "Flow configuration options"
    }
  },
  "$defs": {
    "subtask": {
      "type": "object",
      "required": ["id", "scope", "files", "branch", "status", "checklist"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^task[0-9]+$",
          "description": "Unique subtask identifier (e.g. task1, task2)"
        },
        "scope": {
          "type": "string",
          "description": "Human-readable scope description"
        },
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Files assigned to this subtask (no overlap with other subtasks)"
        },
        "worktree": {
          "type": "string",
          "description": "Absolute path to subtask worktree"
        },
        "branch": {
          "type": "string",
          "minLength": 1,
          "description": "Branch name for this subtask"
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "IDs of subtasks this one depends on"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "completed", "failed"],
          "default": "pending",
          "description": "Subtask execution status"
        },
        "actual_files_changed": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Files actually changed (populated by dev-flow from kickoff.json)"
        },
        "checklist": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["item", "done"],
            "properties": {
              "item": {
                "type": "string",
                "description": "Checklist item description"
              },
              "done": {
                "type": "boolean",
                "default": false,
                "description": "Whether item is completed"
              }
            }
          },
          "minItems": 1,
          "description": "Completion checklist for this subtask"
        }
      }
    },
    "shared_finding": {
      "type": "object",
      "required": ["id", "task_id", "timestamp", "category", "title", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^sf_[0-9]{3,}$",
          "description": "Unique finding id (sf_001, sf_002, ...), generated by flow-append-finding.sh"
        },
        "task_id": {
          "type": "string",
          "description": "ID of the subtask that authored this finding"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 time the finding was appended"
        },
        "category": {
          "type": "string",
          "enum": ["breaking_change", "api_contract", "design_decision", "dependency"]
        },
        "scope": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Files or modules affected by the finding"
        },
        "title": {
          "type": "string",
          "description": "Short human-readable headline"
        },
        "description": {
          "type": "string",
          "description": "Detailed explanation / context"
        },
        "action_required": {
          "type": "string",
          "default": "",
          "description": "What other workers must do in response"
        },
        "acknowledged_by": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Subtask IDs that have read and accepted this finding"
        }
      }
    },
    "integration": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "merging", "integrated", "failed"],
          "description": "Integration phase status"
        },
        "worktree": {
          "type": "string",
          "description": "Absolute path to merge worktree"
        },
        "branch": {
          "type": "string",
          "description": "Integration branch name"
        },
        "merge_results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "task_id": { "type": "string" },
              "status": { "type": "string", "enum": ["merged", "merged_auto_resolved", "conflict", "error", "failed"] },
              "conflicts": {
                "type": "array",
                "items": { "type": "string" }
              },
              "conflict_files": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Files with conflicts for this merge"
              },
              "error": {
                "type": "string",
                "description": "Error message if merge failed"
              }
            }
          },
          "description": "Results of merging each subtask branch"
        },
        "merge_order": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Order in which subtasks were merged"
        },
        "conflicts": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Unresolved conflict files"
        },
        "type_check": {
          "type": ["string", "null"],
          "enum": ["passed", "failed", null],
          "description": "Type checking result (tsc/mypy)"
        },
        "validation": {
          "type": ["string", "null"],
          "enum": ["passed", "failed", null],
          "description": "Integration test result"
        },
        "merged_at": {
          "type": "string",
          "format": "date-time",
          "description": "When integration merge was completed"
        },
        "failed_at_task": {
          "type": "string",
          "description": "Task ID where integration failed"
        },
        "error": {
          "type": "string",
          "description": "Error message if integration failed"
        }
      },
      "description": "Integration phase tracking"
    }
  }
}
