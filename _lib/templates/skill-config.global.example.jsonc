// ~/.claude/skill-config.json - グローバル設定テンプレート
//
// ユーザー共通のプリファレンスを設定します。
// プロジェクト固有の値（base_url, property_id 等）はここに書かず、
// 各プロジェクトの .claude/skill-config.json に記述してください。
//
// 使い方:
//   cp _lib/templates/skill-config.global.example.jsonc ~/.claude/skill-config.json
//   ※ コピー後、コメントを削除して有効な JSON にしてください
{
  "sns-announce": {
    "default_lang": "ja",
    "platforms": {
      "x": { "enabled": true },
      "linkedin": { "enabled": true }
    }
  },
  "sns-schedule-post": {
    "timezone": "Asia/Tokyo",
    "default_platforms": ["x", "linkedin"]
  },
  "trends-analyzer": {
    "geo": "JP",
    "timeframe": "today 3-m"
  },
  "blog-cross-post": {
    "company_name": "Your Company",
    "contact_url": "https://example.com/contact"
  }
}
